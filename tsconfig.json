{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": [
        "./*"
      ],
      "@react-native-picker/picker": [
        "node_modules/@react-native-picker/picker"
      ]
    },
    "typeRoots": [
      "node_modules/@types",
      "types"
    ]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}